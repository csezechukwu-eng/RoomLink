# RoomLink — Supabase configuration
# Copy this file to `.env.local` and fill in values from your Supabase project
# (Project Settings -> API).

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Public anon key (safe to expose; used by the browser client if/when needed)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Phase 1A performs all data access server-side with this key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo mode — LOCAL DEVELOPMENT ONLY.
# Set to "true" to use hardcoded demo data without authentication.
# This is ignored in production (NODE_ENV=production) for safety.
# DEMO_MODE=true
