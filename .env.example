# RoomLink — Supabase configuration
# Copy this file to `.env.local` and fill in values from your Supabase project
# (Project Settings -> API).

# Public project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Public anon key (safe to expose; used by the browser client if/when needed)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Phase 1A performs all data access server-side with this key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo mode — LOCAL DEVELOPMENT ONLY.
# Set to "true" to use hardcoded demo data without authentication.
# This is ignored in production (NODE_ENV=production) for safety.
# DEMO_MODE=true

# Leases are prepared (PDF upload) and signed in-app (signature pad).
# No third-party e-signature provider is required.

# ---------------------------------------------------------------------------
# Application URL (used for Stripe Checkout success/cancel redirects)
# ---------------------------------------------------------------------------
# On Vercel, VERCEL_URL is auto-set and used as fallback.
# For local dev or custom domains, set this explicitly.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Stripe Configuration — TEST MODE ONLY
# ---------------------------------------------------------------------------
# Use Stripe TEST keys only during development/testing.
# Do NOT use live keys until production payment flow is fully tested.
#
# Get test keys from: https://dashboard.stripe.com/test/apikeys

# Secret key — SERVER ONLY. Never expose to the browser.
# Starts with "sk_test_" for test mode.
STRIPE_SECRET_KEY=

# Webhook signing secret — SERVER ONLY.
# For local testing: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and use the "whsec_..." value it provides.
# For deployed endpoints: get from Stripe Dashboard > Webhooks > Signing secret.
STRIPE_WEBHOOK_SECRET=

# Publishable key — Optional for now.
# Not needed until client-side Stripe.js (e.g., Stripe Elements) is introduced.
# When needed, use: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
